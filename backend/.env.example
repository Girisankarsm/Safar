# SafarAI Backend — Environment Template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to GitHub.

# ── Supabase Database (required) ──
# Dashboard → Connect → URI (direct) OR Session pooler (port 5432)
# Replace YOUR_PASSWORD with your Supabase database password (no brackets)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

# Set true to use Supabase PostgreSQL, false for in-memory demo mode
USE_DATABASE=true

# ── Supabase Project (optional) ──
# Dashboard → Settings → API
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ── App Settings ──
DEMO_MODE=false
CORS_ORIGINS=http://localhost:3000
API_V1_PREFIX=/api/v1
