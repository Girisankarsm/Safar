# SafarAI — single environment file (repo root)
# Copy to .env and fill in your values. Never commit .env to GitHub.

# ── Supabase (enter once — used by backend + frontend) ──
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key
# Settings → API → JWT Settings → JWT Secret (for backend token verification)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
USE_DATABASE=true

# ── Backend API ──
DEMO_MODE=true
CORS_ORIGINS=http://localhost:3000
API_V1_PREFIX=/api/v1

# ── Frontend (public — safe in browser) ──
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Mapbox GL JS — navigation-night-v1 style for live trip map (free tier: 50k loads/mo)
# Get a token at https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token
