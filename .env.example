# SafarAI — single environment file (repo root)
# Copy to .env and fill in your values. Never commit .env to GitHub.

# ── Supabase (enter once — used by backend + frontend) ──
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
USE_DATABASE=true

# ── Backend API ──
DEMO_MODE=false
CORS_ORIGINS=http://localhost:3000
API_V1_PREFIX=/api/v1

# ── Frontend (public — safe in browser) ──
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: only if you prefer separate public names (otherwise frontend reads SUPABASE_* above)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
